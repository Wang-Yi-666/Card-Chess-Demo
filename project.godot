; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="newproject"
run/main_scene="res://Scene/SystemFeatureLab.tscn"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GlobalGameSession="*res://Scripts/Battle/Shared/GlobalGameSession.cs"
GameSession="*res://AutoLoad/GameSession.cs"
GlobalBattleContext="*res://AutoLoad/GlobalBattleContext.cs"
PartnerManager="*res://AutoLoad/PartnerManager.cs"

[display]

window/size/viewport_width=320
window/size/viewport_height=180
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"
window/stretch/scale_mode="integer"

[dotnet]

project/assembly_name="newproject"

[gui]

theme/custom="res://Resources/UI/ProjectUiTheme.tres"
theme/custom_font="res://Assets/Fonts/unifont_t-17.0.04.otf"

