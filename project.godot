[layer_names]

2d_physics/layer_1="玩家"
2d_physics/layer_2="环境"
2d_physics/layer_3="怪物"
2d_physics/layer_4="交互物"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0
